generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  HIDDEN
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum LessonTier {
  FREE_TRIAL
  STANDARD
  PREMIUM
  EIKAWA
  PRONUNCIATION_ACTING
  PRONUNCIATION_SINGING
  SPECIALIZED
}

/// Level from the placement activity (unset until completed).
enum PlacedLevel {
  UNSET
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ExerciseType {
  MULTIPLE_CHOICE
  FILL_BLANK
  MATCH_PAIRS
  READING_COMPREHENSION
  SPELLING
  ORDERING
}

/// Leveled flashcard curriculum (Beginner 1–3, Intermediate 1–3, Advanced 1–3).
enum StudyLevelCode {
  BEGINNER_1
  BEGINNER_2
  BEGINNER_3
  INTERMEDIATE_1
  INTERMEDIATE_2
  INTERMEDIATE_3
  ADVANCED_1
  ADVANCED_2
  ADVANCED_3
}

enum StudyDeckVisibility {
  SYSTEM
  PRIVATE
  COMMUNITY
}

enum StudyAssessmentKind {
  LEVEL_EXIT
}

enum BroadcastTarget {
  ALL
  TEACHERS
  STUDENTS
}

// --- Organization / School enums ---

/// Role within an organization (contextual, not platform-wide).
enum OrgRole {
  OWNER // org-wide, full control including billing and deletion
  ORG_ADMIN // org-wide, manages all schools
  SCHOOL_ADMIN // school-scoped, manages one school
  TEACHER // school-scoped, view schedule + request time off
  STUDENT // school-scoped, browse + enroll in classes
}

enum OrgMemberStatus {
  ACTIVE
  INACTIVE
  INVITED
  PENDING_APPROVAL
}

enum TimeOffRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum OrgBillingTarget {
  ORGANIZATION
  STUDENT
}

enum SchoolSlotRecurrence {
  WEEKLY
  DAILY
  ONE_OFF
}

enum SchoolBookingRescheduleRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AvailabilitySlotRecurrence {
  WEEKLY
  ONE_OFF
}

enum PaymentProvider {
  STRIPE
  KOMOJU
}

enum TeacherPaymentAccountStatus {
  PENDING
  ENABLED
  DISABLED
  REQUIREMENTS_DUE
}

enum TeacherPaymentMethodType {
  CARD
  PAYPAY
}

enum PaymentStatus {
  CREATED
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
  EXPIRED
  REFUNDED
}

enum PaymentLedgerEntryType {
  GROSS
  PLATFORM_FEE
  TEACHER_NET
  PROCESSOR_FEE
  REFUND
  TRANSFER_REVERSAL
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  PENDING_RECOVERY
}

enum TeacherPlatformTier {
  TIER_1
  TIER_2
  TIER_3
}

enum TeacherTierEvaluationKind {
  QUARTERLY
  ANNUAL
}

enum TeacherTierEvaluationStatus {
  APPLIED
  NO_CHANGE
  PENDING_ADMIN_APPROVAL
  ADMIN_APPROVED
  ADMIN_KEPT
}

enum TeacherTierAuditAction {
  INITIALIZED
  QUARTERLY_EVALUATED
  ANNUAL_EVALUATED
  ANNUAL_DEMOTION_APPROVED
  ANNUAL_DEMOTION_KEPT
  OVERRIDE_SET
  OVERRIDE_REMOVED
}

// --- NextAuth (Auth.js) ---
model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  role          Role          @default(STUDENT)
  accountStatus AccountStatus @default(ACTIVE)
  locale        String        @default("ja")

  accounts                  Account[]
  sessions                  Session[]
  studentProfile            StudentProfile?
  teacherProfile            TeacherProfile?
  bookingsAsStudent         Booking[]                    @relation("StudentBookings")
  courseProgress            UserCourseProgress[]
  lessonProgress            UserLessonProgress[]
  exerciseAttempts          ExerciseAttempt[]
  sentMessages              ChatMessage[]                @relation("MessageSender")
  receivedMessages          ChatMessage[]                @relation("MessageRecipient")
  notifications             Notification[]
  invoices                  Invoice[]
  teacherStudentLessonRates TeacherStudentLessonRate[]
  chatThreadsAsStudent      ChatThread[]                 @relation("ThreadStudent")
  chatThreadsAsTeacher      ChatThread[]                 @relation("ThreadTeacher")
  broadcastsSent            AdminBroadcast[]             @relation("AdminBroadcastSender")
  ownedStudyDecks           StudyDeck[]                  @relation("StudyDeckOwner")
  studyLevelProgress        UserStudyLevelProgress[]
  studyCardStates           UserStudyCardState[]
  studyAssessmentAttempts   UserStudyAssessmentAttempt[]
  studyQuickReviewDays      StudyQuickReviewDay[]
  googleIntegrationAccount  GoogleIntegrationAccount?
  googleIntegrationSettings GoogleIntegrationSettings?
  organizationMemberships   OrganizationMembership[]
  teacherRosterEntriesAsStudent TeacherRosterEntry[] @relation("RosterStudent")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GoogleIntegrationFeature {
  CALENDAR
  DRIVE
  MEET
}

model GoogleIntegrationAccount {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String    @default("google")
  providerAccountId String
  accessToken       String?   @db.Text
  refreshToken      String?   @db.Text
  expiresAt         DateTime?
  grantedScopes     String[]  @default([])
  tokenMetadataJson Json?
  revoked           Boolean   @default(false)
  disconnectedAt    DateTime?
  lastErrorCode     String?
  lastErrorMessage  String?   @db.Text
  lastSyncedAt      DateTime?
  revocationSource  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId, revoked])
}

model GoogleIntegrationSettings {
  id                          String   @id @default(cuid())
  userId                      String   @unique
  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarConnected           Boolean  @default(false)
  driveConnected              Boolean  @default(false)
  meetConnected               Boolean  @default(false)
  preferredCalendarId         String?  @default("primary")
  defaultNotesFolderId        String?
  autoCreateMeetLink          Boolean  @default(true)
  autoShareNotesWithAttendees Boolean  @default(true)
  artifactSyncEnabled         Boolean  @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StudentProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Student timezone for rendering schedules in their local calendar/time context.
  timezone String @default("Asia/Tokyo")

  /// Result of the in-app placement activity
  placedLevel            PlacedLevel @default(UNSET)
  placedSubLevel         Int?        @default(1)
  placementCompletedAt   DateTime?
  placementNeedsReview   Boolean     @default(false)
  placementReviewReason  String?
  placementReport        Json?
  placementWritingSample String?     @db.Text

  /// One free 20-minute trial per student (set when a trial booking is confirmed)
  trialLessonUsedAt DateTime?

  /// Onboarding data
  learningGoals          String[]  @default([])
  notifyLessonReminders  Boolean   @default(true)
  notifyMessages         Boolean   @default(true)
  notifyPayments         Boolean   @default(true)
  termsAcceptedAt        DateTime?
  privacyAcceptedAt      DateTime?
  recordingConsentAt     DateTime?
  onboardingCompletedAt  DateTime?
  /// Steps the student explicitly skipped from the onboarding checklist.
  skippedOnboardingSteps String[]  @default([])

  /// Short self-introduction / goals; visible to teachers with other profile context.
  shortBio String? @db.VarChar(300)

  /// Platform Stripe Customer for saved payment methods at checkout.
  stripeCustomerId String? @unique
}

model TeacherProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Encrypted refresh token for Google Calendar API (app-level encryption)
  googleCalendarRefreshToken String?   @db.Text
  calendarId                 String?   @default("primary")
  displayName                String?
  bio                        String?   @db.Text
  countryOfOrigin            String?
  credentials                String?   @db.Text
  instructionLanguages       String[]  @default(["EN"])
  specialties                String[]  @default([])
  rateYen                    Int?
  offersFreeTrial            Boolean   @default(true)
  /// When true, profile is hidden from /book marketplace; only rostered students may book via direct link.
  marketplaceHidden          Boolean   @default(false)
  paymentPolicyAcceptedAt    DateTime?
  onboardingCompletedAt      DateTime?
  /// Steps the teacher explicitly skipped from the onboarding wizard.
  skippedOnboardingSteps     String[]  @default([])

  rosterEntries               TeacherRosterEntry[]
  availabilitySlots           AvailabilitySlot[]
  availabilityOccurrenceSkips AvailabilityOccurrenceSkip[]
  bookingsTeaching            Booking[]                    @relation("TeacherBookings")
  lessonOfferings             TeacherLessonOffering[]
  studentLessonRateOverrides  TeacherStudentLessonRate[]
  classLevels                 TeacherClassLevel[]
  classTypes                  TeacherClassType[]
  paymentAccounts             TeacherPaymentAccount[]
  tierState                   TeacherTierState?
  tierEvaluations             TeacherTierEvaluation[]
  tierAuditLogs               TeacherTierAuditLog[]
}

model TeacherTierState {
  id                    String              @id @default(cuid())
  teacherId             String              @unique
  teacher               TeacherProfile      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  calculatedTier        TeacherPlatformTier @default(TIER_1)
  effectiveTier         TeacherPlatformTier @default(TIER_1)
  firstPaidLessonAt     DateTime?
  tierYearStart         DateTime?
  lastEvaluationAt      DateTime?
  nextQuarterlyReviewAt DateTime?
  nextAnnualReviewAt    DateTime?
  overrideTier          TeacherPlatformTier?
  overrideStartsAt      DateTime?
  overrideExpiresAt     DateTime?
  overrideNote          String?             @db.Text
  overrideSetByUserId   String?
  overrideSetAt         DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([effectiveTier])
  @@index([nextQuarterlyReviewAt])
  @@index([nextAnnualReviewAt])
}

model TeacherTierEvaluation {
  id              String                      @id @default(cuid())
  teacherId       String
  teacher         TeacherProfile              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  kind            TeacherTierEvaluationKind
  periodStart     DateTime
  periodEnd       DateTime
  monthlyCountsJson Json
  averageLessons  Float
  recommendedTier TeacherPlatformTier
  appliedTier     TeacherPlatformTier?
  status          TeacherTierEvaluationStatus
  reviewedByUserId String?
  reviewedAt      DateTime?
  reviewNote      String?                     @db.Text
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@unique([teacherId, kind, periodStart, periodEnd])
  @@index([status])
  @@index([teacherId, createdAt])
}

model TeacherTierAuditLog {
  id             String                 @id @default(cuid())
  teacherId      String
  teacher        TeacherProfile         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  actorUserId    String?
  action         TeacherTierAuditAction
  previousTier   TeacherPlatformTier?
  newTier        TeacherPlatformTier?
  note           String?                @db.Text
  metadataJson   Json?
  createdAt      DateTime               @default(now())

  @@index([teacherId, createdAt])
  @@index([action])
}

model TeacherPaymentAccount {
  id                String                      @id @default(cuid())
  teacherId         String
  teacher           TeacherProfile              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  provider          PaymentProvider
  providerAccountId String?
  status            TeacherPaymentAccountStatus @default(PENDING)
  chargesEnabled    Boolean                     @default(false)
  payoutsEnabled    Boolean                     @default(false)
  requirementsDue   String[]                    @default([])
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  methods TeacherPaymentMethod[]
  payments Payment[]

  @@unique([teacherId, provider])
  @@index([teacherId, status])
}

model TeacherPaymentMethod {
  id        String                   @id @default(cuid())
  accountId String
  account   TeacherPaymentAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  method    TeacherPaymentMethodType
  enabled   Boolean                  @default(true)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@unique([accountId, method])
  @@index([method, enabled])
}

/// Students (or pending email invites) allowed to book a marketplace teacher when hidden from the list.
model TeacherRosterEntry {
  id        String         @id @default(cuid())
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentId String?
  student   User?          @relation("RosterStudent", fields: [studentId], references: [id], onDelete: Cascade)
  /// Lowercase normalized email while invite is pending (no User yet).
  invitedEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, studentId])
  @@unique([teacherId, invitedEmail])
  @@index([teacherId])
  @@index([studentId])
}

/// Per-teacher class level taxonomy (e.g. "Beginner", "JLPT N2"). Mirrors
/// SchoolClassLevel but scoped to a marketplace TeacherProfile.
model TeacherClassLevel {
  id        String         @id @default(cuid())
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  /// Stable identifier within the teacher's taxonomy (slug-like).
  /// Auto-generated from labelEn.
  code    String
  labelEn String
  labelJa String?

  sortOrder Int     @default(0)
  active    Boolean @default(true)

  availabilitySlots AvailabilitySlot[]
  lessonOfferings   TeacherLessonOffering[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, code])
  @@index([teacherId, active])
}

/// Per-teacher class type taxonomy (e.g. "Conversation", "Eiken Prep").
model TeacherClassType {
  id        String         @id @default(cuid())
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  code    String
  labelEn String
  labelJa String?

  sortOrder Int     @default(0)
  active    Boolean @default(true)

  availabilitySlots AvailabilitySlot[]
  lessonOfferings   TeacherLessonOffering[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, code])
  @@index([teacherId, active])
}

model TeacherLessonOffering {
  id          String         @id @default(cuid())
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  durationMin Int
  rateYen     Int
  isGroup     Boolean        @default(false)
  groupSize   Int?
  active      Boolean        @default(true)

  /// FK to the teacher's per-teacher class type taxonomy. Drives catalog matching.
  classLevelId String?
  classLevel   TeacherClassLevel? @relation(fields: [classLevelId], references: [id], onDelete: SetNull)
  classTypeId String?
  classType   TeacherClassType? @relation(fields: [classTypeId], references: [id], onDelete: SetNull)

  availabilitySlots AvailabilitySlot[]
  studentRateOverrides TeacherStudentLessonRate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId, isGroup, active])
  @@index([classLevelId])
  @@index([classTypeId])
}

model AvailabilitySlot {
  id        String         @id @default(cuid())
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0-6, Sunday-Saturday in teacher timezone context
  startMin  Int // minutes from midnight local
  endMin    Int
  timezone  String         @default("Asia/Tokyo")

  /// Recurrence pattern. Existing rows default to WEEKLY; new UI-created rows
  /// send ONE_OFF unless the teacher explicitly enables weekly repeat.
  recurrence AvailabilitySlotRecurrence @default(WEEKLY)
  /// Date-only lower bound for ONE_OFF slots, stored as midnight UTC.
  startsOn   DateTime?
  /// Optional inclusive end date for future bounded weekly support.
  endsOn     DateTime?

  /// FK to the teacher's per-teacher class level taxonomy.
  classLevelId String?
  classLevel   TeacherClassLevel? @relation(fields: [classLevelId], references: [id], onDelete: SetNull)
  /// FK to the teacher's per-teacher class type taxonomy.
  classTypeId  String?
  classType    TeacherClassType?  @relation(fields: [classTypeId], references: [id], onDelete: SetNull)
  /// FK to the priced class offer. This is the source of truth for duration/price.
  teacherLessonOfferingId String?
  teacherLessonOffering   TeacherLessonOffering? @relation(fields: [teacherLessonOfferingId], references: [id], onDelete: SetNull)

  active Boolean @default(true)

  @@index([classLevelId])
  @@index([classTypeId])
  @@index([teacherLessonOfferingId])
}

model TeacherStudentLessonRate {
  id        String @id @default(cuid())
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentId String
  student   User @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherLessonOfferingId String
  teacherLessonOffering   TeacherLessonOffering @relation(fields: [teacherLessonOfferingId], references: [id], onDelete: Cascade)
  rateYen Int
  active Boolean @default(true)
  note String? @db.Text
  createdByAdminUserId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherLessonOfferingId, studentId])
  @@index([teacherId, studentId, active])
}

/// Single UTC start hidden for one weekly series occurrence (teacher "this event only" delete).
model AvailabilityOccurrenceSkip {
  id               String         @id @default(cuid())
  teacherProfileId String
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  startsAtIso      String
  createdAt        DateTime       @default(now())

  @@unique([teacherProfileId, startsAtIso])
  @@index([teacherProfileId])
}

model LessonProduct {
  id          String     @id @default(cuid())
  tier        LessonTier
  nameJa      String
  nameEn      String
  durationMin Int
  active      Boolean    @default(true)

  bookings Booking[]
}

model Booking {
  id              String         @id @default(cuid())
  studentId       String
  student         User           @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  teacherId       String
  teacher         TeacherProfile @relation("TeacherBookings", fields: [teacherId], references: [id], onDelete: Cascade)
  lessonProductId String
  lessonProduct   LessonProduct  @relation(fields: [lessonProductId], references: [id])

  startsAt              DateTime
  endsAt                DateTime
  status                BookingStatus
  quotedPriceYen        Int           @default(0)
  manualOverrideUsed    Boolean       @default(false)
  manualOverrideReason  String?       @db.Text
  manualOverrideByRole  Role?
  meetUrl               String?       @db.Text
  googleEventId         String?
  googleCalendarId      String?
  meetConferenceId      String?
  meetCode              String?
  notesDocId            String?
  transcriptArtifactIds String[]      @default([])
  smartNotesIds         String[]      @default([])
  recordingIds          String[]      @default([])
  studentGoogleEventId  String?
  invoice               Invoice?
  payments              Payment[]
  refunds               Refund[]

  /// Teacher-written Markdown lesson notes (visible to student); edited after the lesson ends.
  completionNotesMd     String? @db.Text
  /// External link only (e.g. Google Docs / Meet recap) — we do not host transcript files.
  externalTranscriptUrl String? @db.VarChar(2048)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, startsAt])
  @@index([teacherId, startsAt])
}

model Invoice {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amountYen Int
  invoiceNo String   @unique
  paidAt    DateTime
  createdAt DateTime @default(now())

  @@index([studentId, createdAt])
}

model Payment {
  id                         String                   @id @default(cuid())
  bookingId                  String?                  @unique
  booking                    Booking?                 @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  studentId                  String
  teacherId                  String
  teacherPaymentAccountId    String?
  teacherPaymentAccount      TeacherPaymentAccount?   @relation(fields: [teacherPaymentAccountId], references: [id], onDelete: SetNull)
  provider                   PaymentProvider
  method                     TeacherPaymentMethodType
  amountYen                  Int
  currency                   String                   @default("JPY")
  status                     PaymentStatus            @default(CREATED)
  providerCheckoutId         String?
  providerPaymentId          String?
  idempotencyKey             String                   @unique
  checkoutUrl                String?
  metadataJson               Json?
  paidAt                     DateTime?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt

  ledgerEntries PaymentLedgerEntry[]
  refunds       Refund[]

  @@index([studentId, createdAt])
  @@index([teacherId, createdAt])
  @@index([provider, providerCheckoutId])
  @@index([provider, providerPaymentId])
}

model PaymentLedgerEntry {
  id        String                 @id @default(cuid())
  paymentId String
  payment   Payment                @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  type      PaymentLedgerEntryType
  amountYen Int
  note      String?
  createdAt DateTime               @default(now())

  @@index([paymentId, type])
}

model Refund {
  id               String        @id @default(cuid())
  bookingId        String
  booking          Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  paymentId        String
  payment          Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  provider         PaymentProvider
  providerRefundId String?
  amountYen        Int
  status           RefundStatus  @default(PENDING)
  actor            String
  reason           String
  policyJson       Json?
  recoveryNote     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([bookingId, createdAt])
  @@index([paymentId, createdAt])
  @@index([provider, providerRefundId])
}

model PaymentWebhookEvent {
  id              String          @id @default(cuid())
  provider        PaymentProvider
  providerEventId String
  eventType       String
  processedAt     DateTime        @default(now())
  payloadJson     Json?

  @@unique([provider, providerEventId])
}

// --- Phase 2: Learning ---
model Course {
  id            String  @id @default(cuid())
  slug          String  @unique
  level         String // beginner, intermediate, advanced, eikawa, theme:*
  titleJa       String
  titleEn       String
  descriptionJa String? @db.Text
  descriptionEn String? @db.Text
  sortOrder     Int     @default(0)

  /// When set, this course is scoped to a specific school (org-gated content).
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  units        CourseUnit[]
  userProgress UserCourseProgress[]

  @@index([schoolId])
}

model CourseUnit {
  id        String @id @default(cuid())
  courseId  String
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  titleJa   String
  titleEn   String
  sortOrder Int    @default(0)

  skills Skill[]
}

model Skill {
  id        String     @id @default(cuid())
  unitId    String
  unit      CourseUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  titleJa   String
  titleEn   String
  sortOrder Int        @default(0)

  lessons Lesson[]
}

model Lesson {
  id        String @id @default(cuid())
  skillId   String
  skill     Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  titleJa   String
  titleEn   String
  sortOrder Int    @default(0)

  exercises Exercise[]
  progress  UserLessonProgress[]
}

model Exercise {
  id        String       @id @default(cuid())
  lessonId  String
  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  type      ExerciseType
  /// JSON payload: prompts, options, correct answers (validated in app)
  content   Json
  points    Int          @default(10)
  sortOrder Int          @default(0)

  attempts ExerciseAttempt[]
}

model UserCourseProgress {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  xp          Int       @default(0)
  completedAt DateTime?

  @@unique([userId, courseId])
}

model UserLessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  stars       Int       @default(0)
  completedAt DateTime?

  @@unique([userId, lessonId])
}

model ExerciseAttempt {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  score      Int
  response   Json
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

// --- Study track (flashcards / leveled SRS) ---
model StudyTrack {
  id        String @id @default(cuid())
  slug      String @unique
  titleJa   String
  titleEn   String
  sortOrder Int    @default(0)

  levels StudyLevel[]
}

model StudyLevel {
  id                String         @id @default(cuid())
  trackId           String
  track             StudyTrack     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  levelCode         StudyLevelCode
  titleJa           String
  titleEn           String
  sortOrder         Int            @default(0)
  /// Optional curriculum notes (future MDX / export).
  referenceMarkdown String?        @db.Text

  decks        StudyDeck[]
  assessments  StudyAssessment[]
  userProgress UserStudyLevelProgress[]

  @@unique([trackId, levelCode])
  @@index([trackId, sortOrder])
}

model StudyDeck {
  id          String              @id @default(cuid())
  levelId     String
  level       StudyLevel          @relation(fields: [levelId], references: [id], onDelete: Cascade)
  titleJa     String
  titleEn     String
  sortOrder   Int                 @default(0)
  ownerUserId String?
  ownerUser   User?               @relation("StudyDeckOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  visibility  StudyDeckVisibility @default(SYSTEM)

  cards StudyCard[]

  @@index([levelId, sortOrder])
}

/// Front = learner-facing prompt (`frontJa` DB column): Japanese-heavy at Beginner 1, trending to English at higher levels (see `prompt-locale-policy.ts`). Back = English answer.
model StudyCard {
  id           String    @id @default(cuid())
  deckId       String
  deck         StudyDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  frontJa      String    @db.Text
  backEn       String    @db.Text
  /// Optional structured exercise (reorder tokens, multi-step prompts). Null = classic MCQ from `frontJa` + `backEn`.
  exerciseJson Json?
  sortOrder    Int       @default(0)

  userStates UserStudyCardState[]

  @@index([deckId, sortOrder])
}

model UserStudyLevelProgress {
  id                 String     @id @default(cuid())
  userId             String
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  levelId            String
  level              StudyLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  xp                 Int        @default(0)
  /// 0–100 aggregate mastery for UI (updated on reviews).
  masteryScore       Int        @default(0)
  unlockedAt         DateTime   @default(now())
  completedAt        DateTime?
  assessmentPassedAt DateTime?
  lastStudiedAt      DateTime?

  @@unique([userId, levelId])
  @@index([userId])
}

model UserStudyCardState {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId             String
  card               StudyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  /// MCQ performance (SRS-style ease/reps kept for legacy rows; queue uses counts + dueAt).
  ease               Float     @default(2.5)
  intervalDays       Float     @default(0)
  dueAt              DateTime?
  reps               Int       @default(0)
  lapses             Int       @default(0)
  correctCount       Int       @default(0)
  wrongCount         Int       @default(0)
  streakCorrect      Int       @default(0)
  /// Running mean answer latency (ms) for this card; null until first timed submission.
  averageAnswerMs    Float?
  latencySampleCount Int       @default(0)
  updatedAt          DateTime  @updatedAt

  @@unique([userId, cardId])
  @@index([userId, dueAt])
}

/// Fixed set of up to 5 review cards chosen once per UTC calendar day per user (dashboard quick review).
model StudyQuickReviewDay {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayKey       String
  /// JSON string[] of StudyCard ids
  cardIds      Json
  /// JSON [{ cardId, outcome: "learned" | "not_yet", at: ISO string }]
  interactions Json     @default("[]")
  createdAt    DateTime @default(now())

  @@unique([userId, dayKey])
  @@index([userId])
}

model StudyAssessment {
  id           String              @id @default(cuid())
  levelId      String
  level        StudyLevel          @relation(fields: [levelId], references: [id], onDelete: Cascade)
  kind         StudyAssessmentKind @default(LEVEL_EXIT)
  /// MCQ items: { items: [{ id, promptJa, promptEn, options[], correctIndex }] }
  itemsJson    Json
  passingScore Int                 @default(70)
  sortOrder    Int                 @default(0)

  attempts UserStudyAssessmentAttempt[]

  @@index([levelId, sortOrder])
}

model UserStudyAssessmentAttempt {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentId String
  assessment   StudyAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  score        Int
  /// Map of itemId -> chosenIndex (number)
  answersJson  Json
  passed       Boolean
  createdAt    DateTime        @default(now())

  @@index([userId, createdAt])
}

model ChatThread {
  id                  String    @id @default(cuid())
  studentId           String
  teacherId           String
  student             User      @relation("ThreadStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher             User      @relation("ThreadTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  twoWayEnabled       Boolean   @default(false)
  twoWayEnabledByRole Role?
  studentBlockedAt    DateTime?
  teacherBlockedAt    DateTime?
  studentReportedAt   DateTime?
  teacherReportedAt   DateTime?
  studentReportReason String?   @db.Text
  teacherReportReason String?   @db.Text
  studentArchivedAt   DateTime?
  teacherArchivedAt   DateTime?
  updatedAt           DateTime  @updatedAt

  messages ChatMessage[]

  @@unique([studentId, teacherId])
}

model ChatMessage {
  id          String     @id @default(cuid())
  threadId    String
  thread      ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId    String
  recipientId String
  sender      User       @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User       @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  body        String     @db.Text
  readAt      DateTime?
  createdAt   DateTime   @default(now())

  @@index([threadId, createdAt])
}

model AdminBroadcast {
  id                 String          @id @default(cuid())
  senderId           String
  sender             User            @relation("AdminBroadcastSender", fields: [senderId], references: [id], onDelete: Cascade)
  target             BroadcastTarget
  body               String          @db.Text
  targetedRecipients Int
  sentMessages       Int
  createdAt          DateTime        @default(now())

  @@index([senderId, createdAt])
  @@index([createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  titleJa   String
  titleEn   String
  bodyJa    String?   @db.Text
  bodyEn    String?   @db.Text
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

/// Authoritative placement MCQ bank (loaded by API only; never bundled to the browser).
model PlacementBankQuestion {
  id            String  @id
  stemId        String?
  weight        Int
  cefrBand      String
  section       String
  instructionEn String  @db.Text
  instructionJa String  @db.Text
  questionEn    String  @db.Text
  questionJa    String  @db.Text
  optionsEn     Json
  optionsJa     Json
  correctIndex  Int

  @@index([cefrBand, section])
}

// --- Organization / School ---

/// Top-level entity representing a company or school group (e.g. "ABC English Group").
model Organization {
  id            String  @id @default(cuid())
  slug          String  @unique
  name          String
  nameJa        String?
  nameEn        String?
  timezone      String  @default("Asia/Tokyo")
  logoUrl       String?
  description   String? @db.Text
  descriptionJa String? @db.Text

  billingTarget OrgBillingTarget @default(ORGANIZATION)

  /// Future: custom domain for white-label school URL.
  customDomain String? @unique

  schools     School[]
  memberships OrganizationMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Operational unit under an Organization (e.g. "ABC Shibuya").
/// All schedules, enrollment, pricing, and content are scoped to a School.
model School {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String
  name           String
  nameJa         String?
  nameEn         String?
  /// Overrides org timezone if set; otherwise inherits from org.
  timezone       String?
  logoUrl        String?
  description    String?      @db.Text
  descriptionJa  String?      @db.Text

  /// Future: custom domain for this specific school.
  customDomain String? @unique

  memberships     OrganizationMembership[]
  scheduleSlots   SchoolScheduleSlot[]
  pricing         SchoolLessonPricing[]
  bookings        SchoolBooking[]
  timeOffRequests TimeOffRequest[]
  courses         Course[]
  classLevels     SchoolClassLevel[]
  classTypes      SchoolClassType[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

/// Joins a User to an Organization, optionally scoped to a specific School.
/// schoolId = null → org-wide role (OWNER, ORG_ADMIN).
/// schoolId = X   → school-scoped role (SCHOOL_ADMIN, TEACHER, STUDENT).
model OrganizationMembership {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Null until the invited email signs in for the first time, at which
  /// point the auth signIn callback links the membership to the User row.
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId       String?
  school         School?      @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  orgRole OrgRole
  status  OrgMemberStatus @default(INVITED)

  invitedByUserId String?
  invitedAt       DateTime?
  joinedAt        DateTime?
  /// Email the admin invited. On sign-in, the user is matched here by email.
  inviteEmail     String?

  teacherScheduleSlots SchoolScheduleSlot[]
  classEnrollments     SchoolClassEnrollment[]
  bookingsAsTeacher    SchoolBooking[]         @relation("SchoolBookingTeacher")
  bookingAttendances   SchoolBookingAttendee[]
  timeOffRequests      TimeOffRequest[]
  schoolRescheduleRequestsSubmitted SchoolBookingRescheduleRequest[] @relation("SchoolRescheduleRequester")
  schoolRescheduleRequestsReviewed  SchoolBookingRescheduleRequest[] @relation("SchoolRescheduleReviewer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId, schoolId])
  @@unique([organizationId, inviteEmail, schoolId])
  @@index([userId])
  @@index([organizationId, orgRole])
  @@index([schoolId])
  @@index([inviteEmail])
}

/// Recurring weekly class slot managed by SCHOOL_ADMIN.
model SchoolScheduleSlot {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  assignedTeacherMembershipId String?
  assignedTeacher             OrganizationMembership? @relation(fields: [assignedTeacherMembershipId], references: [id], onDelete: SetNull)

  dayOfWeek Int // 0-6 (Sun-Sat)
  startMin  Int // minutes from midnight
  endMin    Int // minutes from midnight
  timezone  String // resolved from school or org

  labelJa String?
  labelEn String?

  classLevelId String?
  classLevel   SchoolClassLevel? @relation(fields: [classLevelId], references: [id], onDelete: SetNull)
  classTypeId  String?
  classType    SchoolClassType?  @relation(fields: [classTypeId], references: [id], onDelete: SetNull)

  capacity    Int @default(1) // 1 = private, >1 = group
  durationMin Int

  active Boolean @default(true)

  /// Recurrence pattern. WEEKLY (default) honors `dayOfWeek` and/or `daysOfWeek`.
  /// DAILY emits one occurrence per calendar day. ONE_OFF emits a single
  /// occurrence on `startsOn` (which is required for ONE_OFF).
  recurrence SchoolSlotRecurrence @default(WEEKLY)
  /// Optional multi-day weekly pattern. When non-empty, supersedes `dayOfWeek`.
  /// Each entry is 0-6 (Sun-Sat).
  daysOfWeek Int[]                @default([])
  /// Optional inclusive lower bound for occurrence emission (date-only, midnight UTC).
  startsOn   DateTime?
  /// Optional inclusive upper bound for occurrence emission (date-only, midnight UTC).
  endsOn     DateTime?

  skips       SchoolScheduleSkip[]
  enrollments SchoolClassEnrollment[]
  bookings    SchoolBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, active])
  @@index([classLevelId])
  @@index([classTypeId])
}

/// Per-school grade/level taxonomy (e.g. "Year 7", "JLPT N2", "Eiken Pre-2").
/// Schools define their own list rather than reusing the marketplace's
/// fixed beginner/intermediate/advanced enum.
model SchoolClassLevel {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  /// Stable identifier within the school (slug-like). Auto-generated from labelEn.
  code    String
  /// Required English/canonical display name.
  labelEn String
  /// Optional Japanese override; falls back to labelEn when null.
  labelJa String?
  /// Optional sort order — lower values appear first.
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  scheduleSlots SchoolScheduleSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, code])
  @@index([schoolId, active])
}

/// Per-school class type taxonomy (e.g. "Eiken Prep", "Conversation Club", "JLPT N2 Reading").
model SchoolClassType {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  code      String
  labelEn   String
  labelJa   String?
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  scheduleSlots SchoolScheduleSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, code])
  @@index([schoolId, active])
}

/// Single occurrence cancellation for a recurring school schedule slot.
model SchoolScheduleSkip {
  id             String             @id @default(cuid())
  scheduleSlotId String
  scheduleSlot   SchoolScheduleSlot @relation(fields: [scheduleSlotId], references: [id], onDelete: Cascade)
  startsAtIso    String

  reason          String?
  createdByUserId String

  createdAt DateTime @default(now())

  @@unique([scheduleSlotId, startsAtIso])
}

/// Student enrolled in a recurring school class.
model SchoolClassEnrollment {
  id                  String                 @id @default(cuid())
  scheduleSlotId      String
  scheduleSlot        SchoolScheduleSlot     @relation(fields: [scheduleSlotId], references: [id], onDelete: Cascade)
  studentMembershipId String
  studentMembership   OrganizationMembership @relation(fields: [studentMembershipId], references: [id], onDelete: Cascade)

  active       Boolean   @default(true)
  enrolledAt   DateTime  @default(now())
  unenrolledAt DateTime?

  @@unique([scheduleSlotId, studentMembershipId])
  @@index([studentMembershipId])
}

/// Materialized class instance (one occurrence of a recurring slot).
model SchoolBooking {
  id                  String                 @id @default(cuid())
  schoolId            String
  school              School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  scheduleSlotId      String
  scheduleSlot        SchoolScheduleSlot     @relation(fields: [scheduleSlotId], references: [id])
  teacherMembershipId String
  teacherMembership   OrganizationMembership @relation("SchoolBookingTeacher", fields: [teacherMembershipId], references: [id])

  startsAt          DateTime
  endsAt            DateTime
  meetUrl           String?  @db.Text
  googleEventId     String?
  completionNotesMd String?  @db.Text

  attendees SchoolBookingAttendee[]
  rescheduleRequests SchoolBookingRescheduleRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, startsAt])
  @@index([teacherMembershipId, startsAt])
}

/// Teacher-proposed new time for a materialized school class; school admins approve or reject.
model SchoolBookingRescheduleRequest {
  id                      String @id @default(cuid())
  schoolBookingId       String
  schoolBooking           SchoolBooking @relation(fields: [schoolBookingId], references: [id], onDelete: Cascade)
  requesterMembershipId String
  requesterMembership   OrganizationMembership @relation("SchoolRescheduleRequester", fields: [requesterMembershipId], references: [id], onDelete: Cascade)
  proposedStartsAt      DateTime
  proposedEndsAt        DateTime
  status                SchoolBookingRescheduleRequestStatus @default(PENDING)
  reviewedByMembershipId String?
  reviewedByMembership   OrganizationMembership? @relation("SchoolRescheduleReviewer", fields: [reviewedByMembershipId], references: [id], onDelete: SetNull)
  reviewedAt            DateTime?
  rejectReason          String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolBookingId, status])
}

/// Per-student attendance record for a materialized school class.
model SchoolBookingAttendee {
  id                  String                 @id @default(cuid())
  schoolBookingId     String
  schoolBooking       SchoolBooking          @relation(fields: [schoolBookingId], references: [id], onDelete: Cascade)
  studentMembershipId String
  studentMembership   OrganizationMembership @relation(fields: [studentMembershipId], references: [id])

  attended Boolean?

  createdAt DateTime @default(now())

  @@unique([schoolBookingId, studentMembershipId])
}

/// School-level pricing rules (set by SCHOOL_ADMIN).
model SchoolLessonPricing {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  lessonLevel String?
  lessonType  String?
  durationMin Int
  priceYen    Int
  isGroup     Boolean @default(false)
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, active])
}

/// Teacher time-off request, pending approval by SCHOOL_ADMIN.
model TimeOffRequest {
  id                  String                 @id @default(cuid())
  schoolId            String
  school              School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherMembershipId String
  teacherMembership   OrganizationMembership @relation(fields: [teacherMembershipId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime
  reason    String?  @db.Text

  status           TimeOffRequestStatus @default(PENDING)
  reviewedByUserId String?
  reviewedAt       DateTime?
  reviewNote       String?              @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, status])
  @@index([teacherMembershipId])
}
