# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep .env.example tracked for onboarding)
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# LLM placement bank audit outputs (regenerate with yarn placement-bank:llm-audit)
/data/placement-bank-llm-audit.checkpoint.jsonl
/data/placement-bank-llm-audit.summary.json

# LLM placement bank regen / fix checkpoints & backups (machine-local; not part of the canonical bank)
/data/placement-bank-regenerate-llm*.checkpoint.jsonl
/data/placement-bank-llm-fix-bad.checkpoint.jsonl
/data/placement-bank.backup-*/
/data/placement-bank-level-backups/

# prisma generated client (regenerated via `prisma generate`)
/src/generated/

# typescript
*.tsbuildinfo
next-env.d.ts

