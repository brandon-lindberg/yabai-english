# Copy this file to `.env` (and optionally `.env.local`). Prisma CLI reads `.env` only.
#
# Database (PostgreSQL — use Render or local)
DATABASE_URL="postgresql://user:password@localhost:5432/english_platform?schema=public"

# Placement questions are read from Postgres (`PlacementBankQuestion`). Seed with `yarn db:seed`
# after `yarn placement-bank:reset` if `data/placement-bank/*.json` changed.

# Optional: semantic LLM audit of the JSON bank (`yarn placement-bank:llm-audit`, writes data/placement-bank-llm-audit.*)
# Study flashcards (no API): `yarn study:build-beginner1-json` / `yarn study:build-beginner2-json` → `apps/web/data/study/beginner-*.json`; then `yarn db:seed`
# Optional OpenAI bank generator (same output path): `yarn study:generate-beginner-1 --run --write` — requires OPENAI_API_KEY in apps/web/.env
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4
# PLACEMENT_LLM_BATCH=12

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (Auth.js + optional Calendar)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Optional local bypass when Google OAuth is not set (dev only).
# DEV_AUTH_BYPASS=true

# App URL (no trailing slash) — used by Auth.js
AUTH_TRUST_HOST=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001
REALTIME_SERVER_URL=http://localhost:3001
SERVER_EMIT_SECRET="secret"
REALTIME_SERVER_SECRET="secret"

# Optional: encrypt teacher Google Calendar refresh tokens at rest (32 bytes hex)
# CALENDAR_TOKEN_ENCRYPTION_KEY=

# Apple Sign In (optional)
# AUTH_APPLE_ID=
# AUTH_APPLE_SECRET=

# LINE Login (optional — custom provider config in auth.ts)
# AUTH_LINE_ID=
# AUTH_LINE_SECRET=

# Realtime service (Phase 2 / chat)
# NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
