# Database (PostgreSQL — use Render or local)
DATABASE_URL="postgresql://user:password@localhost:5432/english_platform?schema=public"

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (Auth.js + optional Calendar)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# App URL (no trailing slash) — used by Auth.js and Stripe redirects
AUTH_TRUST_HOST=true
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: encrypt teacher Google Calendar refresh tokens at rest (32 bytes hex)
# CALENDAR_TOKEN_ENCRYPTION_KEY=

# Apple Sign In (optional)
# AUTH_APPLE_ID=
# AUTH_APPLE_SECRET=

# LINE Login (optional — custom provider config in auth.ts)
# AUTH_LINE_ID=
# AUTH_LINE_SECRET=

# Realtime service (Phase 2 / chat)
# NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
